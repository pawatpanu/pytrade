# MT5 Connection
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
APP_DEFAULT_ROLE=viewer
APP_ADMIN_PASSWORD=PorPorpanupat_052
# Example: C:\\Program Files\\MetaTrader 5\\terminal64.exe
MT5_PATH=

# Symbols (comma separated)
SYMBOLS=BTCUSD,ETHUSD,SOLUSD,XRPUSD,BNBUSD,DOGEUSD

# Timeframes
TIMEFRAME_PRIMARY=H4
TIMEFRAME_CONFIRM=H1
TIMEFRAME_SETUP=M15
TIMEFRAME_TRIGGER=M5

# Scanner
BARS_TO_FETCH=600
SCAN_INTERVAL_SECONDS=60
SYNC_INTERVAL_SECONDS=30
SUMMARY_INTERVAL_SECONDS=300
SIGNAL_PROFILE=custom
# SIGNAL_PROFILE options: aggressive | normal | strict | custom
LOG_LEVEL=INFO
DB_PATH=signals.db
DRY_RUN=true
MIN_ALERT_CATEGORY=alert
ACCOUNT_BALANCE=10000
RISK_PER_TRADE_PCT=1.0
USE_MT5_BALANCE_FOR_SIZING=true
RISK_BALANCE_SOURCE=equity
SL_ATR_MULTIPLIER=1.5
TARGET_RR=1.8

# Execution (demo-only safety first)
ENABLE_EXECUTION=false
EXECUTION_MODE=demo
MIN_EXECUTE_CATEGORY=strong
MAX_OPEN_POSITIONS=2
ENABLE_PREMIUM_STACK=true
PREMIUM_STACK_EXTRA_SLOTS=1
ENABLE_ULTRA_STACK=true
ULTRA_STACK_SCORE=95
ULTRA_STACK_EXTRA_SLOTS=2
DAILY_LOSS_LIMIT=200
ORDER_COOLDOWN_MINUTES=30
MAX_SLIPPAGE_POINTS=100
FIXED_LOT=0.01
MAGIC_NUMBER=20260312
ENABLE_SMART_EXIT=true
ENABLE_BREAK_EVEN=true
BREAK_EVEN_TRIGGER_R=1.0
BREAK_EVEN_LOCK_R=0.1
ENABLE_TRAILING_STOP=true
TRAILING_START_R=1.5
TRAILING_DISTANCE_R=1.0
ENABLE_PARTIAL_CLOSE=false
PARTIAL_CLOSE_TRIGGER_R=1.5
PARTIAL_CLOSE_RATIO=0.5
LOG_SKIPPED_REASONS=execution_disabled,execution_mode_not_demo,max_open_positions_reached,daily_loss_limit_reached,account_info_unavailable,account_not_demo,symbol_trade_disabled

# Hard Filters
ADX_MINIMUM=18
ENTRY_ZONE_MAX_ATR=1.8
HARD_FILTER_MODE=strict
M5_MIN_TRIGGERS=2
ANTI_DUP_SCORE_DELTA=5

# Thresholds
WATCHLIST_THRESHOLD=75
ALERT_THRESHOLD=85
STRONG_ALERT_THRESHOLD=90
PREMIUM_ALERT_THRESHOLD=93

# RSI Context
RSI_BUY_LOW=45
RSI_BUY_HIGH=60
RSI_SELL_LOW=40
RSI_SELL_HIGH=55

# Weights (optional override)
WEIGHTS=higher_tf:20,ema_alignment:15,adx_strength:10,market_structure:10,setup_quality:10,rsi_context:8,macd_confirmation:8,stoch_trigger:5,volume_confirmation:5,bollinger_context:4,atr_suitability:5

# Indicator Toggles
USE_EMA=true
USE_RSI=true
USE_MACD=true
USE_BBANDS=true
USE_ADX=true
USE_ATR=true
USE_STOCH=true
USE_VWAP=false
USE_SUPERTREND=false

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# LINE
LINE_ENABLED=false
LINE_TOKEN=

# Backtest
BACKTEST_BARS=2500
BACKTEST_FORWARD_BARS=12

# News + Volume Risk Filters
ENABLE_VOLUME_REGIME_FILTER=true
VOLUME_RATIO_M5_MIN=0.85
VOLUME_RATIO_M15_MIN=0.95
VOLUME_RATIO_H1_MIN=0.60
VOLUME_MIN_CONFIRMATIONS=2
ENABLE_NEWS_FILTER=true
NEWS_FAIL_OPEN=true
NEWS_FETCH_TIMEOUT_SECONDS=6
NEWS_REFRESH_SECONDS=180
NEWS_LOOKBACK_MINUTES=180
NEWS_BLOCK_MINUTES=45
NEWS_KEYWORDS=gold,xau,bullion,fed,fomc,rate,cpi,ppi,nfp,treasury,yield,usd,dollar,war,sanction,tariff
NEWS_SOURCES=https://news.google.com/rss/search?q=XAUUSD+OR+gold+price+OR+Federal+Reserve&hl=en-US&gl=US&ceid=US:en,https://news.google.com/rss/search?q=US+CPI+OR+PPI+OR+NFP+OR+Treasury+yields&hl=en-US&gl=US&ceid=US:en

